{
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=CommunityCarDbRF;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=True;",
    "Redis": "localhost:6379"
  },
  "JwtSettings": {
    "SecretKey": "DemoSecretKey-ChangeThisInProduction-32Chars!",
    "Issuer": "CommunityCarApi",
    "Audience": "CommunityCarClient",
    "ExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "EmailSettings": {
    "From": "demo@example.com",
    "FromName": "Community Car Demo",
    "SmtpServer": "smtp.example.com",
    "Port": 587,
    "Username": "your-email@example.com",
    "Password": "your-password-here",
    "EnableSsl": true
  },
  "FileStorage": {
    "BasePath": "wwwroot/uploads",
    "MaxFileSizeMB": 10
  },
  "AdminUser": {
    "Email": "admin@demo.com",
    "Password": "Demo@123456"
  },
  "AllowedOrigins": [
    "http://localhost:3000",
    "http://localhost:5075",
    "https://localhost:7075"
  ],
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 60
      },
      {
        "Endpoint": "*",
        "Period": "1h",
        "Limit": 1000
      },
      {
        "Endpoint": "*/api/auth/*",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "POST:*/api/*",
        "Period": "1m",
        "Limit": 30
      }
    ]
  },
  "IpRateLimitPolicies": {
    "IpRules": []
  },
  "AllowedHosts": "*"
}
