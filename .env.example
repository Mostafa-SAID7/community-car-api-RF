# Community Car API - Environment Variables Example
# Copy this file to .env and update with your values

# Database Connection
DB_SERVER=(localdb)\\mssqllocaldb
DB_NAME=CommunityCarDb
DB_USER=
DB_PASSWORD=

# JWT Settings
JWT_SECRET_KEY=YourSecretKeyHere-MustBeAtLeast32Characters!
JWT_ISSUER=CommunityCarApi
JWT_AUDIENCE=CommunityCarClient
JWT_EXPIRATION_MINUTES=60

# Email Settings (Optional for demo)
EMAIL_FROM=demo@example.com
EMAIL_FROM_NAME=Community Car Demo
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=your-password
SMTP_ENABLE_SSL=true

# Redis (Optional)
REDIS_CONNECTION=localhost:6379

# Admin User (First Run)
ADMIN_EMAIL=admin@demo.com
ADMIN_PASSWORD=Demo@123456

# File Storage
FILE_STORAGE_PATH=wwwroot/uploads
MAX_FILE_SIZE_MB=10

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5075,https://localhost:7075
